{
  "name": "@birchcraft/mcp-weapp-cli",
  "version": "1.0.0",
  "description": "微信小程序开发者工具 CLI 的 MCP 服务器实现",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-weapp-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test dist/tests/**/*.test.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "weapp",
    "miniprogram",
    "wechat",
    "devtools",
    "cli",
    "modelcontextprotocol"
  ],
  "author": "birchcraft <you@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/birchcraft/mcp-weapp-cli.git"
  },
  "bugs": {
    "url": "https://github.com/birchcraft/mcp-weapp-cli/issues"
  },
  "homepage": "https://github.com/birchcraft/mcp-weapp-cli#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
